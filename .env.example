# TERA Application Environment Configurations

# 1. Fireworks AI API Authentication
# Get your API key from https://fireworks.ai/
FIREWORKS_API_KEY=your-api-key-here

# 2. Fireworks Base Endpoint URL
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# 3. Allowed Models (Comma-separated list of model names authorized for routing)
ALLOWED_MODELS=accounts/fireworks/models/deepseek-v4-pro,accounts/fireworks/models/gpt-oss-120b

# 4. Bounded Concurrency limit (for batch execution)
MAX_CONCURRENCY=4

# Local AMD inference safety. External fallback is opt-in and disabled by default.
TERA_EXTERNAL_FALLBACK_ENABLED=false
TERA_MODEL_TIMEOUT_SEC=120
TERA_LOCAL_INFERENCE_URL=http://127.0.0.1:8000/v1
TERA_LOCAL_MODEL_NAME=Qwen/Qwen2.5-Coder-7B-Instruct
TERA_POWER_INFERENCE_URL=http://127.0.0.1:8001/v1
TERA_POWER_MODEL_NAME=Qwen/Qwen2.5-14B-Instruct

# 5. Frontend API Base URL (Leave empty in Docker Space/production to use relative host URLs)
# NEXT_PUBLIC_API_URL=http://localhost:8000
