# TERA Application Environment Configurations

# Bounded concurrency limit for batch execution.
MAX_CONCURRENCY=4

# Local AMD inference. Both tiers must be loopback vLLM endpoints.
# Gemma 4 requires a Gemma-compatible vLLM release; vLLM 0.16 is insufficient.
TERA_MODEL_TIMEOUT_SEC=120
TERA_LOCAL_INFERENCE_URL=http://127.0.0.1:8000/v1
TERA_LOCAL_MODEL_NAME=google/gemma-4-E4B-it
TERA_POWER_INFERENCE_URL=http://127.0.0.1:8001/v1
TERA_POWER_MODEL_NAME=google/gemma-4-26B-A4B-it

TERA_CACHE_DIR=/tmp/tera/cache
TERA_ONNX_MODEL_PATH=/app/models/minilm.onnx
TERA_SEMANTIC_CACHE_ENABLED=true
TERA_TELEMETRY_PATH=/output/telemetry.json
TERA_RESULTS_PATH=/output/results.json

# 5. Frontend API Base URL (Leave empty in Docker Space/production to use relative host URLs)
# NEXT_PUBLIC_API_URL=http://localhost:8000
